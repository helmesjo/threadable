libs =
import libs += \
  libthreadable%lib{threadable} \
  doctest%lib{doctest}

if($cxx.id == 'gcc')
{
  cxx.coptions += -Wno-interference-size
}

exe{threadable-tests}: {hxx ixx txx cxx}{** -execution.test.cxx -function.test.cxx -atomic.test.cxx -ring_buffer.test.cxx -ring_iterator.cxx} $libs
{
  test = true
  install = false
  test.arguments = --no-intro
}

cxx.poptions =+ "-I$out_root" "-I$src_root"
